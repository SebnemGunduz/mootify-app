<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".form">

    <ImageView
        android:id="@+id/imageView9"
        android:layout_width="452dp"
        android:layout_height="685dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.512"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/formyeni" />

    <TextView
        android:textSize="14dp"
        android:layout_marginTop="10dp"
        android:id="@+id/startbutton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="20dp"
        app:layout_constraintEnd_toEndOf="@id/sifreal"
        app:layout_constraintStart_toEndOf="@+id/signup"
        app:layout_constraintTop_toBottomOf="@id/sifreal"
        android:textColor="@color/white"
        android:text="Login"

        />

    <EditText
        android:textColorHint="@color/white"
        android:id="@+id/sifreal"
        android:layout_width="170dp"
        android:layout_height="40dp"
        android:layout_marginEnd="103dp"
        android:layout_marginBottom="320dp"

        android:ems="10"
        android:hint="Password"
        android:inputType="numberSigned"
        android:textSize="14dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/isimal"
        tools:visibility="visible"
        android:background="@android:color/transparent"
        />

    <EditText
        android:textColorHint="@color/white"
        android:id="@+id/isimal"
        android:layout_width="150dp"
        android:layout_height="40dp"
        android:layout_marginTop="358dp"
        android:layout_marginEnd="26dp"
        android:layout_marginBottom="10dp"
        android:layout_marginLeft="15dp"
        android:ems="10"
        android:hint="Name"
        android:inputType="text"
        android:textSize="14dp"
        app:layout_constraintBottom_toTopOf="@+id/sifreal"
        app:layout_constraintEnd_toEndOf="@+id/sifreal"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="@+id/sifreal"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible"
        android:background="@android:color/transparent"/>

    <TextView
        android:textSize="14dp"
        android:layout_marginTop="10dp"
        android:text="Sign Up"
        android:id="@+id/signup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="135dp"
        app:layout_constraintEnd_toStartOf="@+id/startbutton"
        app:layout_constraintStart_toStartOf="@+id/sifreal"
        app:layout_constraintTop_toBottomOf="@+id/sifreal"
       android:textColor="@color/white"/>
    <TextView
        android:id="@+id/gizli"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:textSize="20dp"
        app:layout_constraintStart_toStartOf="@+id/sifreal"
        app:layout_constraintEnd_toEndOf="@+id/sifreal"
        app:layout_constraintTop_toBottomOf="@+id/sifreal"
        android:layout_marginTop="70dp"
        android:visibility="invisible"
        />




</androidx.constraintlayout.widget.ConstraintLayout>